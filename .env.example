# Spotwise environment — copy to .env (gitignored) and fill in.

# ─── Server ───
# CORS / cookie origin. "*" = dev (also enables /api/docs). Set a real origin in prod.
ALLOWED_ORIGIN=*
# Host port the frontend publishes in local `make dev`.
FRONTEND_PORT=80

# ─── Auth (required) ───
# Session cookie signing secret, >= 32 chars. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
# In production this comes from the Docker file secret `spotwise_session_secret` instead.
SESSION_SECRET=

# Allow public signup. true in dev; false in prod.
ALLOW_SIGNUP=true

# ─── Data sources ───
# ENTSO-E Transparency token (free, email registration). Optional — the forecast layer
# degrades to day-ahead-only when absent.
ENTSOE_API_TOKEN=

# ─── Production only (used by docker-compose.prod.yml / Makefile) ───
# DOMAIN=example.com          # app served at https://spotwise.${DOMAIN}
