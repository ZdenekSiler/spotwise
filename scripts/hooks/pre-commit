#!/usr/bin/env bash
# Block commits that introduce possible secrets (detect-secrets against the baseline).
set -euo pipefail
ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT/backend"

STAGED=$(git diff --cached --name-only --diff-filter=ACM | grep -vE '^backend/tests/' || true)
[ -z "$STAGED" ] && exit 0

echo "pre-commit: scanning for secrets…"
uv run detect-secrets-hook --baseline ../.secrets.baseline $STAGED || {
  echo "pre-commit: possible secret detected — review before committing"; exit 1;
}
